# SM Zentrix API — Environment Variables
PORT=3000

# SMTP — Gmail App Password setup:
# 1. Go to myaccount.google.com → Security → 2-Step Verification (enable it)
# 2. Then go to: myaccount.google.com/apppasswords
# 3. Create an app password for "Mail" → copy the 16-char password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password

FROM_EMAIL=your_gmail@gmail.com
TO_EMAIL=rahulshindeit7@gmail.com

ADMIN_PASSWORD=smzentrix@admin2024

FRONTEND_URL=http://localhost:5173
